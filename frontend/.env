# =========================================================================
# 🌍 MÔI TRƯỜNG & HIỂN THỊ 
# =========================================================================
# Tên ứng dụng (Dùng để hiển thị trên Title, Logo, Email)
NEXT_PUBLIC_APP_NAME=Carevia-Platform

# Phiên bản ứng dụng (Tùy chọn)
NEXT_PUBLIC_APP_VERSION=1.0.0

# =========================================================================
# 🔌 CẤU HÌNH API (KẾT NỐI BACKEND)
# =========================================================================
# URL gốc của Backend Spring Boot (Lưu ý: Thêm /api nếu backend dùng prefix này)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1
# Timeout cho mỗi lần gọi API (tính bằng miliseconds - ví dụ 10 giây)
NEXT_PUBLIC_API_TIMEOUT=10000

# =========================================================================
# 🔑 CẤU HÌNH AUTHENTICATION (JWT / LOCALSTORAGE)
# =========================================================================
# Key dùng để lưu Token vào LocalStorage/Cookie (Để tránh trùng với các web khác)
NEXT_PUBLIC_AUTH_TOKEN_KEY=carevia_access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=carevia_refresh_token

# =========================================================================
# 🛠️ CẤU HÌNH KHÁC (SOCIAL LOGIN - Nếu có)
# =========================================================================
# Ví dụ nếu sau này bạn dùng Google Login
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_://googleusercontent.com
